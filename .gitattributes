# Skill content and data files MUST stay LF — the Ed25519 signatures in
# manifest.json cover the exact byte content of each skill.md. A Windows
# checkout that rewrites LF → CRLF would invalidate every signature on
# disk. Normalize to LF on commit and check out as LF on every platform.
*.md         text eol=lf
*.json       text eol=lf
*.js         text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.pem        text eol=lf

# Shell scripts MUST stay LF — run inside Linux CI runners; bash chokes
# on CRLF with "$'\r': command not found".
*.sh         text eol=lf

# Standard binary types.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.tgz        binary
*.pdf        binary

# Lockfiles — keep diff-friendly but never auto-rewrite.
package-lock.json    text eol=lf -diff

# Extension-less text files that ship in the tarball MUST stay LF —
# sbom.cdx.json records SHA-256 of these by-byte, and a CRLF rewrite
# on Windows checkout would flip the hash and trip the v0.13.9
# check-sbom-currency per-file integrity gate. Same logic as the
# manifest.json signing — operator-visible bytes must be platform-
# stable.
LICENSE              text eol=lf
NOTICE               text eol=lf
AUTHORS              text eol=lf
CODEOWNERS           text eol=lf
*.sha256             text eol=lf
keys/EXPECTED_FINGERPRINT  text eol=lf
vendor/**/LICENSE    text eol=lf
vendor/**/NOTICE     text eol=lf
vendor/**/AUTHORS    text eol=lf
