# Dotfiles and local config — catch-all first
.*
!.gitignore
!.gitattributes
!.gitleaks.toml
!.cursorrules
!.windsurfrules
!.dockerignore
!.npmrc
!.github
# Track the test-count baseline so CI can compare against it.
!tests/.test-count-baseline.json
# Track the version-tag drift baseline so CI can compare against it.
!tests/.version-tag-baseline.json
# Track the version-bump authorization (an authorized minor/major commits this
# so the cadence gate can verify it in CI); the `.*` catch-all above hides it.
!tests/.version-bump-ack.json

# Node
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
out/

# Runtime artifacts
findings.json
scan-output.json
.bootstrap-complete
refresh-report.json
.cache/
*.tmp
*.bak

# OS artifacts
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor artifacts
*.swp
*.swo
*~
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Environment and secrets — never commit
.env
.env.*
*.pem
!keys/public.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Local-only working docs — design scratch, specs, and plans live here and are
# not operator-facing. Kept out of the repo explicitly (not only via a machine's
# global ignore) so a fresh clone or a contributor without that global config
# can't accidentally commit them.
docs/

# Python (for any tooling)
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# E2E test fixtures intentionally contain dotfiles + a fixture node_modules
# tarball to simulate real-world host configurations for detection tests.
# Each exception is per-pattern (rather than a sweeping fixtures/** override)
# so future fixture inputs that match new ignore rules surface as untracked
# instead of being silently swept in. These come last so they take
# precedence over the catch-all .* and the node_modules/ rule above.
!tests/e2e-scenarios/*/fixtures/.claude
!tests/e2e-scenarios/*/fixtures/.claude/**
!tests/e2e-scenarios/*/fixtures/.vscode
!tests/e2e-scenarios/*/fixtures/.vscode/**
!tests/e2e-scenarios/*/fixtures/.aws
!tests/e2e-scenarios/*/fixtures/.aws/**
!tests/e2e-scenarios/*/fixtures/.zshrc
!tests/e2e-scenarios/*/fixtures/home/.aws
!tests/e2e-scenarios/*/fixtures/home/.aws/**
!tests/e2e-scenarios/*/fixtures/node_modules
!tests/e2e-scenarios/*/fixtures/node_modules/**
