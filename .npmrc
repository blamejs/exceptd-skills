save-exact=true
engine-strict=true
package-lock=true
fund=false
audit=false
; Registry cooldown — refuse fresh-publish supply-chain worms. CVE-2026-45321
; (Mini Shai-Hulud TanStack worm, 2026-05-11) was caught publicly within 20
; minutes of publish; 72h (4320 minutes) is overkill-safe. `minimumReleaseAge`
; (minutes) is the canonical config key from npm 11+. The npm 10.x `before=`
; key takes an ISO date, NOT a duration, and is deprecated in favor of
; `minimumReleaseAge` — left here as a comment for operators on older clients
; who can pin a specific date manually:
;   before=2026-05-10
minimumReleaseAge=4320
